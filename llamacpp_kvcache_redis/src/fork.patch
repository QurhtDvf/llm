+
+// === LMCache-compatible chunk API (fork addition) ===
+
+void llama_kv_cache::state_write_chunk(
+        llama_io_write_i & io,
+        uint32_t token_start,
+        uint32_t token_count) const {
+    GGML_ASSERT(token_start + token_count <= v_cells[0].size());
+    cell_ranges_t cr { 0, {{ token_start, token_start + token_count }} };
+    state_write_meta(io, cr);
+    state_write_data(io, cr);
+}
+
+bool llama_kv_cache::state_read_chunk(
+        llama_io_read_i & io,
+        uint32_t token_start,
+        uint32_t token_count) {
+    GGML_ASSERT(token_start + token_count <= v_cells[0].size());
+    slot_info sinfo;
+    sinfo.s0 = 0; sinfo.s1 = 0;
+    sinfo.resize(1);
+    sinfo.strm[0] = 0;
+    sinfo.idxs[0].resize(token_count);
+    for (uint32_t i = 0; i < token_count; ++i)
+        sinfo.idxs[0][i] = token_start + i;
+    return state_read_meta(io, 0, token_count, sinfo)
+        && state_read_data(io, 0, token_count, sinfo);
+}
+
+size_t llama_kv_cache::get_chunk_size_bytes(uint32_t token_count) const {
+    size_t total = token_count * 12 + 8;
+    for (const auto & layer : layers) {
+        total += 12 + ggml_row_size(layer.k->type,
+                     hparams.n_embd_k_gqa(layer.il)) * token_count;
+        total += 12 + ggml_row_size(layer.v->type,
+                     hparams.n_embd_v_gqa(layer.il)) * token_count;
+    }
+    return total;
+}
+// === end fork addition ===
